---
import "../styles/global.css";

const siteUrl = "https://thescreen.cam";
const title = "ScreenCam - Native macOS screen recording, directed after capture";
const description =
  "ScreenCam is a native macOS screen recorder for sharp capture, high-refresh workflows, manual camera control, curve tuning, and preview-accurate export.";
const downloadPath = "/api/download/release";
const nightlyPath = "/api/download/nightly";
const packageSizeFallback = "...";
const features = [
  {
    number: "01",
    title: "Native, compact",
    copy: `Native macOS app. ${packageSizeFallback} download.`
  },
  {
    number: "02",
    title: "Hi-res motion",
    copy: "Retina capture with high refresh-rate support."
  },
  {
    number: "03",
    title: "Custom curves",
    copy: "Shape camera animation with editable easing curves."
  },
  {
    number: "04",
    title: "Manual lens",
    copy: "Pure manual camera mode for directed shots."
  }
];
const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "ScreenCam",
  applicationCategory: "MultimediaApplication",
  operatingSystem: "macOS 15+",
  url: siteUrl,
  image: `${siteUrl}/og.png`,
  downloadUrl: `${siteUrl}${downloadPath}`,
  description,
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD"
  },
  featureList: [
    "Native macOS screen recording",
    "High-resolution and high-refresh-rate capture",
    "Manual camera controls",
    "Animation curve editing",
    "Preview-accurate export"
  ]
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#050505" />
    <meta name="color-scheme" content="dark" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="apple-mobile-web-app-title" content="ScreenCam" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={siteUrl} />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ScreenCam" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={`${siteUrl}/og.png`} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="ScreenCam dark landing page with native recorder interface" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/og.png`} />
    <meta name="twitter:image:alt" content="ScreenCam dark landing page with native recorder interface" />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <div class="header-mask" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>

    <header class="site-header" aria-label="Primary navigation">
      <a class="brand" href="/" aria-label="ScreenCam home">
        <img src="/icon-192.png" width="32" height="32" alt="" decoding="async" />
        <span>ScreenCam</span>
      </a>
      <a class="header-download" href={downloadPath} data-release-download>Download</a>
    </header>

    <main id="main">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-layout">
          <div class="hero-copy">
            <img class="hero-mark" src="/app-icon-512.png" width="128" height="128" alt="" decoding="async" />
            <p class="eyebrow">Native macOS capture studio</p>
            <h1 id="hero-title">Capture sharp. Direct the frame.</h1>
            <p class="hero-line">
              High-resolution recording with a camera you can shape after the take.
            </p>
            <div class="hero-actions" aria-label="Download ScreenCam">
              <a class="button button-primary download-button" href={downloadPath} data-release-download>
                <span>Download for macOS</span>
                <small data-release-size aria-live="polite">{packageSizeFallback}</small>
              </a>
              <a class="button button-subtle" href={nightlyPath} data-nightly-download>Nightly</a>
            </div>
          </div>

          <div class="studio-preview" aria-label="ScreenCam editor and recorder preview">
            <div class="product-toolbar" aria-label="ScreenCam recording toolbar demo">
              <button class="toolbar-close" type="button" aria-label="Close toolbar">
                <svg viewBox="0 0 24 24"><path d="M7 7l10 10M17 7L7 17" /></svg>
              </button>
              <span class="toolbar-separator"></span>
              <button class="toolbar-target" type="button" aria-label="Capture display">
                <svg viewBox="0 0 24 24"><rect x="4" y="4" width="16" height="11" rx="1.5" /><path d="M12 15v4M8 20h8" /></svg>
                <em>Display</em>
              </button>
              <button class="toolbar-target" type="button" aria-label="Capture window">
                <svg viewBox="0 0 24 24"><rect x="4" y="5" width="16" height="14" rx="2" /><path d="M7 8h1M10 8h1M13 8h1" /></svg>
                <em>Window</em>
              </button>
              <button class="toolbar-target" type="button" aria-label="Capture area">
                <svg viewBox="0 0 24 24"><path d="M8 4H6.5A2.5 2.5 0 0 0 4 6.5V8M16 4h1.5A2.5 2.5 0 0 1 20 6.5V8M20 16v1.5A2.5 2.5 0 0 1 17.5 20H16M8 20H6.5A2.5 2.5 0 0 1 4 17.5V16" /></svg>
                <em>Area</em>
              </button>
              <span class="toolbar-separator"></span>
              <button class="toolbar-icon toolbar-toggle" type="button" aria-label="Toggle camera" aria-pressed="false" data-toolbar-toggle>
                <svg viewBox="0 0 24 24"><path d="M4 8.5A2.5 2.5 0 0 1 6.5 6H14a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H6.5A2.5 2.5 0 0 1 4 15.5v-7Z" /><path d="M16 10l4-2.5v9L16 14" /></svg>
                <span class="toggle-slash"></span>
              </button>
              <button class="toolbar-icon toolbar-toggle" type="button" aria-label="Toggle microphone" aria-pressed="false" data-toolbar-toggle>
                <svg viewBox="0 0 24 24"><path d="M12 4a3 3 0 0 1 3 3v4a3 3 0 0 1-6 0V7a3 3 0 0 1 3-3Z" /><path d="M6 11a6 6 0 0 0 12 0M12 19v3M8 22h8" /></svg>
                <span class="toggle-slash"></span>
              </button>
              <button class="toolbar-icon toolbar-toggle" type="button" aria-label="Toggle system audio" aria-pressed="true" data-toolbar-toggle>
                <svg viewBox="0 0 24 24"><path d="M4 10v4h4l5 4V6L8 10H4Z" /><path d="M16 9a4 4 0 0 1 0 6M18.5 6.5a7.5 7.5 0 0 1 0 11" /></svg>
                <span class="toggle-slash"></span>
              </button>
              <span class="toolbar-separator"></span>
              <button class="toolbar-icon" type="button" aria-label="Open workspace">
                <svg viewBox="0 0 24 24"><path d="M3.5 7.5h6l2 2H20a1.5 1.5 0 0 1 1.5 1.5v7A2.5 2.5 0 0 1 19 20.5H5A2.5 2.5 0 0 1 2.5 18V9A1.5 1.5 0 0 1 4 7.5Z" /><path d="M3 11h18" /></svg>
              </button>
              <button class="toolbar-icon" type="button" aria-label="Open settings">
                <svg viewBox="0 0 24 24"><path d="M12 8.4a3.6 3.6 0 1 0 0 7.2 3.6 3.6 0 0 0 0-7.2Z" /><path d="M19 13.5a7.9 7.9 0 0 0 0-3l2-1.5-2-3.4-2.4 1a8.2 8.2 0 0 0-2.6-1.5L13.7 2h-3.4L10 5.1a8.2 8.2 0 0 0-2.6 1.5l-2.4-1-2 3.4 2 1.5a7.9 7.9 0 0 0 0 3L3 15l2 3.4 2.4-1a8.2 8.2 0 0 0 2.6 1.5l.3 3.1h3.4l.3-3.1a8.2 8.2 0 0 0 2.6-1.5l2.4 1 2-3.4-2-1.5Z" /></svg>
              </button>
            </div>

            <div class="preview-window">
              <div class="window-top">
                <span></span><span></span><span></span>
                <em>00:18.42</em>
              </div>
              <div class="capture-stage">
                <span class="target-frame"></span>
                <span class="focus-ring"></span>
                <span class="cursor-vector"></span>
              </div>
            </div>

            <div class="editor-chrome" aria-hidden="true">
              <div class="timeline-strip">
                <span class="clip clip-a"></span>
                <span class="clip clip-b"></span>
                <span class="clip clip-c"></span>
                <span class="playhead"></span>
              </div>
              <div class="inspector-strip">
                <span>Frame</span>
                <span>Cursor</span>
                <span>Curve</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="section feature-section" id="native" aria-labelledby="native-title">
        <div class="section-copy">
          <p class="eyebrow">Capture / direct / export</p>
          <h2 id="native-title">One native loop.</h2>
        </div>
        <div class="feature-grid">
          {features.map((feature) => (
            <article class="feature-card">
              <span>{feature.number}</span>
              <h3>{feature.title}</h3>
              {feature.number === "01" ? (
                <p>
                  <span>Native macOS app.</span>{" "}
                  <strong data-release-size aria-live="polite">{packageSizeFallback}</strong>{" "}
                  <span>download.</span>
                </p>
              ) : (
                <p>{feature.copy}</p>
              )}
            </article>
          ))}
        </div>
      </section>

      <section class="download-band" aria-labelledby="download-title">
        <div>
          <p class="eyebrow">Download</p>
          <h2 id="download-title">Start with the stable build.</h2>
        </div>
        <div class="download-actions">
          <a class="button button-primary" href={downloadPath} data-release-download>Download production</a>
          <a class="nightly-link" href={nightlyPath} data-nightly-download>Nightly build</a>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <span>ScreenCam</span>
      <a href={downloadPath} data-release-download>Download</a>
      <a href="/privacy">Privacy</a>
      <span>macOS 15+</span>
    </footer>
    <script is:inline>
      (() => {
        const formatSize = (bytes) => {
          if (!Number.isFinite(bytes) || bytes <= 0) return null;
          const mib = bytes / 1024 / 1024;
          return `${mib.toFixed(mib >= 10 ? 1 : 2)} MiB`;
        };

        const updateLinks = (selector, url) => {
          if (typeof url !== "string" || !url) return;
          document.querySelectorAll(selector).forEach((link) => {
            link.href = url;
          });
        };

        fetch("/api/downloads.json", { cache: "no-store" })
          .then((response) => (response.ok ? response.json() : null))
          .then((payload) => {
            updateLinks("[data-release-download]", payload?.release?.url);
            updateLinks("[data-nightly-download]", payload?.nightly?.url);

            const releaseSize = formatSize(payload?.release?.size);
            if (releaseSize) {
              document.querySelectorAll("[data-release-size]").forEach((target) => {
                target.textContent = releaseSize;
              });
            }
          })
          .catch(() => {});
      })();

      (() => {
        document.querySelectorAll("[data-toolbar-toggle]").forEach((button) => {
          button.addEventListener("click", () => {
            const isOn = button.getAttribute("aria-pressed") === "true";
            button.setAttribute("aria-pressed", String(!isOn));
          });
        });
      })();
    </script>
  </body>
</html>
