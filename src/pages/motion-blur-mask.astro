---
import "../styles/global.css";
import { Footer } from "../components/footer";
import { MotionBlurMaskTool } from "../components/motion-blur-mask-tool";
import { SiteHeader } from "../components/site-header";

const siteUrl = "https://thescreen.cam";
const title = "Motion Blur Mask Tool - ScreenCam";
const description =
  "Upload an image, draw rectangular motion blur masks, tune blur strength and direction, then export the composited result.";
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#050505" />
    <meta name="color-scheme" content="dark" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="apple-mobile-web-app-title" content="ScreenCam" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={`${siteUrl}/motion-blur-mask`} />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ScreenCam" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`${siteUrl}/motion-blur-mask`} />
    <meta property="og:image" content={`${siteUrl}/og.jpg`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/og.jpg`} />
  </head>
  <body class="font-sans antialiased bg-background text-foreground">
    <a class="skip-link" href="#main">Skip to content</a>
    <SiteHeader client:load />

    <main id="main">
      <MotionBlurMaskTool client:load />
    </main>

    <Footer showProductLinks={false} client:load />
  </body>
</html>
