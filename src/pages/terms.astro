---
import "../styles/global.css";

const siteUrl = "https://thescreen.cam";
const title = "Terms of Use - ScreenCam";
const description =
  "ScreenCam's terms of use explain the app license, subscriptions, purchases, and support contact information.";
const appleStandardEULA = "https://www.apple.com/legal/internet-services/itunes/dev/stdeula/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#050505" />
    <meta name="color-scheme" content="dark" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="apple-mobile-web-app-title" content="ScreenCam" />
    <meta name="robots" content="index, follow" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={`${siteUrl}/terms`} />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ScreenCam" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`${siteUrl}/terms`} />
    <meta property="og:image" content={`${siteUrl}/og.png`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/og.png`} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <div class="header-mask" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>

    <header class="site-header" aria-label="Primary navigation">
      <a class="brand" href="/" aria-label="ScreenCam home">
        <img src="/icon-192.png" width="32" height="32" alt="" decoding="async" />
        <span>ScreenCam</span>
      </a>
      <a class="header-download" href="/">Home</a>
    </header>

    <main id="main" class="legal-page">
      <article class="legal-document">
        <p class="eyebrow">Terms</p>
        <h1>Terms of Use</h1>
        <p class="legal-updated">Last updated: May 20, 2026</p>

        <section>
          <h2>App license</h2>
          <p>
            ScreenCam is licensed to you under Apple's Standard End User License Agreement
            (EULA), unless otherwise required by applicable law. You can review Apple's Standard
            EULA at <a href={appleStandardEULA}>apple.com/legal/internet-services/itunes/dev/stdeula</a>.
          </p>
        </section>

        <section>
          <h2>Subscriptions and purchases</h2>
          <p>
            ScreenCam Pro subscriptions and purchases are processed by Apple through the Mac App
            Store. Subscription billing, renewal, cancellation, refunds, and account management are
            handled through your Apple ID and App Store account settings.
          </p>
        </section>

        <section>
          <h2>Use of ScreenCam</h2>
          <p>
            You are responsible for the recordings, files, and exports you create with ScreenCam.
            Only record, edit, and share content when you have the rights and permissions required
            to do so.
          </p>
        </section>

        <section>
          <h2>Privacy</h2>
          <p>
            ScreenCam's privacy practices are described in the
            <a href="/privacy">Privacy Policy</a>.
          </p>
        </section>

        <section>
          <h2>Contact</h2>
          <p>
            If you have questions about these terms, contact us at
            <a href="mailto:cats_juice@outlook.com">cats_juice@outlook.com</a>.
          </p>
        </section>
      </article>
    </main>

    <footer class="site-footer">
      <span>ScreenCam</span>
      <a href="/terms">Terms</a>
      <a href="/privacy">Privacy</a>
      <span>macOS 15+</span>
    </footer>
  </body>
</html>
