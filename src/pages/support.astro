---
import "../styles/global.css";

const siteUrl = "https://thescreen.cam";
const supportEmail = "cats_juice@outlook.com";
const title = "Support - ScreenCam";
const description =
  "Get help with ScreenCam for macOS, including recording permissions, microphone access, exports, purchases, and support contact information.";
const supportMailto = `mailto:${supportEmail}?subject=ScreenCam%20Support`;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: title,
  url: `${siteUrl}/support`,
  description,
  contactPoint: {
    "@type": "ContactPoint",
    contactType: "customer support",
    email: supportEmail,
    availableLanguage: ["en", "zh-Hans"]
  }
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#050505" />
    <meta name="color-scheme" content="dark" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="apple-mobile-web-app-title" content="ScreenCam" />
    <meta name="robots" content="index, follow" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={`${siteUrl}/support`} />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ScreenCam" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`${siteUrl}/support`} />
    <meta property="og:image" content={`${siteUrl}/og.png`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/og.png`} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <div class="header-mask" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>

    <header class="site-header" aria-label="Primary navigation">
      <a class="brand" href="/" aria-label="ScreenCam home">
        <img src="/icon-192.png" width="32" height="32" alt="" decoding="async" />
        <span>ScreenCam</span>
      </a>
      <a class="header-download" href="/">Home</a>
    </header>

    <main id="main" class="legal-page">
      <article class="legal-document">
        <p class="eyebrow">Support</p>
        <h1>ScreenCam Support</h1>
        <p class="legal-updated">Last updated: May 20, 2026</p>

        <section>
          <h2>Contact support</h2>
          <p>
            For questions, bug reports, purchase issues, or help using ScreenCam, email
            <a href={supportMailto}>{supportEmail}</a>. We usually reply within two business days.
          </p>
        </section>

        <section>
          <h2>What to include</h2>
          <p>
            Please include your ScreenCam version, macOS version, Mac model, the recording mode you
            used, and a short description of what happened. If the issue is about export or playback,
            include the export settings and whether the problem happens in preview too.
          </p>
        </section>

        <section>
          <h2>Recording permissions</h2>
          <p>
            ScreenCam may ask macOS for Screen Recording, Microphone, Camera, and file access. You
            can review or reset these permissions in System Settings, then reopen ScreenCam and try
            the recording again.
          </p>
        </section>

        <section>
          <h2>Microphone and audio</h2>
          <p>
            If microphone or system audio is missing, confirm the microphone is selected in
            ScreenCam, check that ScreenCam is allowed to use the microphone in System Settings, and
            make a short test recording before starting a longer session.
          </p>
        </section>

        <section>
          <h2>Privacy and terms</h2>
          <p>
            ScreenCam is designed to process recordings locally on your Mac. Learn more in the
            <a href="/privacy">Privacy Policy</a> and <a href="/terms">Terms of Use</a>.
          </p>
        </section>
      </article>
    </main>

    <footer class="site-footer">
      <span>ScreenCam</span>
      <a href="/support">Support</a>
      <a href="/terms">Terms</a>
      <a href="/privacy">Privacy</a>
      <span>macOS 15+</span>
    </footer>
  </body>
</html>
