---
import "../styles/global.css";
import { appStoreUrl, siteUrl } from "../lib/i18n";
import type { Locale } from "../lib/i18n";
import { getTranslation } from "../lib/translations";
import { CustomControlsSection } from "./custom-controls-section";
import { DeviceMockupsSection } from "./device-mockups-section";
import { FAQSection } from "./faq-section";
import { FeatureCardsSection } from "./feature-cards-section";
import { Footer } from "./footer";
import { Hero } from "./hero";
import PageHead from "./page-head.astro";
import { PerformanceSection } from "./performance-section";
import { SmoothScroll } from "./smooth-scroll";
import { ZoomFeatureSection } from "./zoom-feature-section";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslation(locale);
const meta = t.meta.home;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "ScreenCam",
  applicationCategory: "MultimediaApplication",
  operatingSystem: "macOS 15+",
  url: siteUrl,
  image: `${siteUrl}/og.jpg`,
  downloadUrl: appStoreUrl,
  description: meta.description,
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
  featureList: t.home.structuredDataFeatureList,
};
---

<!doctype html>
<html lang={locale} class="dark">
  <head>
    <PageHead
      locale={locale}
      path="/"
      title={meta.title}
      description={meta.description}
      robots="index, follow, max-image-preview:large"
      structuredData={structuredData}
    />
  </head>
  <body class="font-sans antialiased bg-background">
    <SmoothScroll client:media="(hover: hover) and (pointer: fine)" />
    <main>
      <Hero
        copy={t.home.hero}
        currentPath="/"
        headerCopy={t.header}
        languageLabel={t.footer.language}
        locale={locale}
        client:load
      />
      <ZoomFeatureSection copy={t.home.zoom} client:visible={{ rootMargin: "-25% 0px" }} />
      <DeviceMockupsSection copy={t.home.deviceMockups} client:visible={{ rootMargin: "-25% 0px" }} />
      <CustomControlsSection copy={t.home.controls} client:visible={{ rootMargin: "-25% 0px" }} />
      <PerformanceSection copy={t.home.performance} client:visible={{ rootMargin: "-25% 0px" }} />
      <FeatureCardsSection copy={t.home.featureCards} client:visible={{ rootMargin: "-25% 0px" }} />
      <FAQSection copy={t.home.faq} client:visible={{ rootMargin: "-25% 0px" }} />
      <Footer copy={t.footer} locale={locale} client:visible={{ rootMargin: "-25% 0px" }} />
    </main>
  </body>
</html>
