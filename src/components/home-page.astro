---
import "../styles/global.css";
import { appStoreUrl, localizedPath, siteUrl } from "../lib/i18n";
import type { Locale } from "../lib/i18n";
import { getTranslation } from "../lib/translations";
import { CustomControlsSection } from "./custom-controls-section";
import { DeviceMockupsSection } from "./device-mockups-section";
import { DocsBasicsSection } from "./docs-basics-section";
import { FAQSection } from "./faq-section";
import { FeatureCardsSection } from "./feature-cards-section";
import { Footer } from "./footer";
import { Hero } from "./hero";
import PageHead from "./page-head.astro";
import { PerformanceSection } from "./performance-section";
import { SmoothScroll } from "./smooth-scroll";
import { ZoomFeatureSection } from "./zoom-feature-section";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslation(locale);
const meta = t.meta.home;
const isEnglish = locale === "en";
const docsBasicsCopy = {
  emptyVideoDescription: t.docs.emptyVideoDescription,
  emptyVideoTitle: t.docs.emptyVideoTitle,
  eyebrow: t.docs.eyebrow,
  feature: t.docs.features.basics,
  playback: t.docs.playback,
  progressLabel: t.docs.progressLabel,
  title: t.docs.title,
  videoAriaLabel: t.docs.videoAriaLabel,
};
const softwareApplicationStructuredData = {
  "@type": "SoftwareApplication",
  "@id": `${siteUrl}/#software`,
  name: "ScreenCam",
  applicationCategory: "MultimediaApplication",
  operatingSystem: "macOS 15+",
  url: siteUrl,
  image: `${siteUrl}/og.jpg`,
  downloadUrl: appStoreUrl,
  description: meta.description,
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    url: appStoreUrl,
  },
  featureList: t.home.structuredDataFeatureList,
};
const faqStructuredData = {
  "@type": "FAQPage",
  "@id": `${siteUrl}${localizedPath(locale, "/")}#faq-schema`,
  mainEntity: t.home.faq.items.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [softwareApplicationStructuredData, faqStructuredData],
};
---

<!doctype html>
<html lang={locale} class="dark">
  <head>
    <PageHead
      locale={locale}
      path="/"
      title={meta.title}
      description={meta.description}
      robots="index, follow, max-image-preview:large"
      structuredData={structuredData}
    />
  </head>
  <body class="font-sans antialiased bg-background">
    <SmoothScroll client:media="(hover: hover) and (pointer: fine)" />
    <main>
      <Hero
        copy={t.home.hero}
        currentPath="/"
        headerCopy={t.header}
        languageLabel={t.footer.language}
        locale={locale}
        client:load
      />
      <ZoomFeatureSection copy={t.home.zoom} client:visible={{ rootMargin: "-25% 0px" }} />
      <DeviceMockupsSection copy={t.home.deviceMockups} client:visible={{ rootMargin: "-25% 0px" }} />
      <CustomControlsSection copy={t.home.controls} client:visible={{ rootMargin: "-25% 0px" }} />
      <PerformanceSection copy={t.home.performance} client:visible={{ rootMargin: "-25% 0px" }} />
      <FeatureCardsSection copy={t.home.featureCards} client:visible={{ rootMargin: "-25% 0px" }} />
      {isEnglish && (
        <section class="bg-background px-6 py-24 md:px-12" aria-labelledby="screen-studio-alternative-link">
          <div class="mx-auto grid max-w-6xl gap-8 border-y border-border/60 py-12 md:grid-cols-[1fr_auto] md:items-center">
            <div>
              <p class="mb-3 text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">Screen Studio Alternative</p>
              <h2 id="screen-studio-alternative-link" class="max-w-3xl text-3xl font-semibold leading-tight tracking-tight text-foreground md:text-5xl">
                Need a lighter Mac screen recorder with deeper manual control?
              </h2>
              <p class="mt-5 max-w-2xl text-base leading-7 text-muted-foreground">
                Compare ScreenCam with Screen Studio across app size, CPU and memory use, export speed, manual zoom anchors, layers, device mockups, and export formats.
              </p>
            </div>
            <a
              class="group inline-flex w-fit items-center gap-2 bg-foreground px-5 py-3 text-sm font-medium text-background transition-colors hover:bg-foreground/90"
              href="/screen-studio-alternative"
            >
              Screen Studio alternative for Mac
              <svg
                aria-hidden="true"
                class="h-4 w-4 transition-transform group-hover:translate-x-1"
                fill="none"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path d="M5 12h14"></path>
                <path d="m12 5 7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </section>
      )}
      <DocsBasicsSection copy={docsBasicsCopy} docsHref={localizedPath(locale, "/docs")} client:visible />
      <FAQSection copy={t.home.faq} client:visible={{ rootMargin: "-25% 0px" }} />
      <Footer copy={t.footer} locale={locale} client:visible={{ rootMargin: "-25% 0px" }} />
    </main>
  </body>
</html>
