---
import "../styles/global.css";
import { localizedPath } from "../lib/i18n";
import type { Locale } from "../lib/i18n";
import { getTranslation } from "../lib/translations";
import type { RichTextSegment } from "../lib/translations";
import { Footer } from "./footer";
import PageHead from "./page-head.astro";
import { SiteHeader } from "./site-header";

type LegalPageKey = "privacy" | "support" | "terms";

interface Props {
  locale: Locale;
  page: LegalPageKey;
}

const { locale, page } = Astro.props;
const t = getTranslation(locale);
const content = t.legal[page];
const meta = t.meta[page];
const path = `/${page}`;

function getSegmentHref(segment: Exclude<RichTextSegment, string>) {
  return segment.href.startsWith("/") ? localizedPath(locale, segment.href) : segment.href;
}
---

<!doctype html>
<html lang={locale}>
  <head>
    <PageHead locale={locale} path={path} title={meta.title} description={meta.description} />
  </head>
  <body class="font-sans antialiased bg-background text-foreground">
    <a class="skip-link" href="#main">{t.common.skipToContent}</a>
    <SiteHeader
      copy={t.header}
      currentPath={path}
      languageLabel={t.footer.language}
      locale={locale}
      client:load
    />

    <main id="main" class="legal-page">
      <article class="legal-document">
        <p class="eyebrow">{content.eyebrow}</p>
        <h1>{content.title}</h1>
        <p class="legal-updated">{content.updated}</p>

        {content.sections.map((section) => (
          <section>
            <h2>{section.title}</h2>
            {section.paragraphs.map((paragraph, paragraphIndex) => (
              <p class:list={{ "mt-4": paragraphIndex > 0 }}>
                {paragraph.map((segment) =>
                  typeof segment === "string" ? (
                    segment
                  ) : (
                    <a href={getSegmentHref(segment)}>{segment.text}</a>
                  )
                )}
              </p>
            ))}

            {section.showSupportChannels && (
              <div class="support-channel-list" aria-label={content.supportChannelsAria}>
                <a href="https://x.com/cats_juice" target="_blank" rel="noopener noreferrer">
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M18.9 2h3.68l-8.04 9.19L24 22h-7.41l-5.8-7.58L4.15 22H.47l8.6-9.83L0 2h7.59l5.24 6.93L18.9 2Zm-1.29 18.1h2.04L6.48 3.8H4.29L17.61 20.1Z"></path>
                  </svg>
                  <span>X / Twitter</span>
                </a>
                <a href="https://discord.gg/23hVAxmj53" target="_blank" rel="noopener noreferrer">
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M19.54 5.34A16.77 16.77 0 0 0 15.35 4c-.18.33-.39.78-.53 1.13a15.6 15.6 0 0 0-4.65 0A11.8 11.8 0 0 0 9.63 4a16.7 16.7 0 0 0-4.2 1.34C2.78 9.31 2.06 13.18 2.42 17c1.78 1.32 3.51 2.12 5.2 2.65.42-.57.79-1.18 1.11-1.83-.61-.23-1.19-.52-1.74-.85.15-.11.29-.22.43-.34a11.95 11.95 0 0 0 10.16 0c.14.12.28.23.43.34-.55.33-1.13.62-1.74.85.32.65.69 1.26 1.11 1.83 1.69-.53 3.42-1.33 5.2-2.65.43-4.43-.73-8.26-3.04-11.66ZM8.76 14.65c-1.02 0-1.86-.94-1.86-2.09s.82-2.1 1.86-2.1c1.04 0 1.88.94 1.86 2.1 0 1.15-.82 2.09-1.86 2.09Zm6.48 0c-1.02 0-1.86-.94-1.86-2.09s.82-2.1 1.86-2.1c1.04 0 1.88.94 1.86 2.1 0 1.15-.82 2.09-1.86 2.09Z"></path>
                  </svg>
                  <span>Discord</span>
                </a>
              </div>
            )}
          </section>
        ))}
      </article>
    </main>

    <Footer copy={t.footer} locale={locale} showProductLinks={false} client:load />
  </body>
</html>
